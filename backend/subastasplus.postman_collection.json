            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Juan\",\n  \"apellido\": \"Pérez\",\n  \"email\": \"juan.perez@ejemplo.com\",\n  \"domicilioLegal\": \"Av. Corrientes 1234, CABA\",\n  \"paisOrigen\": \"Argentina\",\n  \"dniFrente\": \"data:image/jpeg;base64,<base64>\",\n  \"dniDorso\": \"data:image/jpeg;base64,<base64>\"\n}"
            }
          }

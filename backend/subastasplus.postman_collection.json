        {
          "name": "Etapa 2 - Crear clave",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/v1/registro/etapa2", "host": ["{{baseUrl}}"], "path": ["v1","registro","etapa2"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tokenSeguimiento\": \"tok_<valor>\",\n  \"email\": \"juan.perez@ejemplo.com\",\n  \"clave\": \"MiClave123\"\n}"
            }
          }
        },
        {
          "name": "Verificar Token de Seguimiento",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/v1/registro/verificar-token", "host": ["{{baseUrl}}"], "path": ["v1","registro","verificar-token"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tokenSeguimiento\": \"tok_<valor>\"\n}"
            }
          }
        }
      ]
    },
